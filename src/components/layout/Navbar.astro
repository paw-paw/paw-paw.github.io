---
import ThemeToggle from '../ui/ThemeToggle.astro';
import { t } from '../../utils/i18n';

const lang = Astro.currentLocale || 'en';
---

<header id="navbar" class="fixed top-0 z-50 w-full transition-all duration-300">
  <div class="max-w-container mx-auto px-6 pt-4">
    <div class="surface-muted flex items-center justify-between px-5 py-4 shadow-button">
      <a href="/" class="brand-lockup" aria-label="Homepage">
        <span class="brand-badge">P</span>
        <span class="brand-wordmark">Pawpaw</span>
      </a>

      <nav class="hidden md:flex items-center gap-8">
        <ul class="flex items-center gap-7 text-[0.95rem]">
          <li>
            <a href="/" class="nav-link">{t('nav.home', lang)}</a>
          </li>
          <li>
            <a href="/work/" class="nav-link">{t('nav.work', lang)}</a>
          </li>
          <li>
            <a href="/experience/" class="nav-link">{t('nav.experience', lang)}</a>
          </li>
          <li>
            <a href="/#contact" class="nav-link">{t('nav.contact', lang)}</a>
          </li>
        </ul>
        <ThemeToggle />
      </nav>

      <div class="flex items-center gap-4 md:hidden">
        <ThemeToggle />
        <button id="mobile-menu-button" class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-secondary/10 bg-white/75 text-secondary dark:border-fog/10 dark:bg-neutral-darkSoft/80 dark:text-fog" aria-label="Toggle Menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu">
            <line x1="4" x2="20" y1="12" y2="12"></line>
            <line x1="4" x2="20" y1="6" y2="6"></line>
            <line x1="4" x2="20" y1="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="mt-3 hidden md:hidden">
      <div class="surface-muted px-6 py-5">
        <ul class="flex flex-col space-y-4 text-sm">
          <li>
            <a href="/" class="mobile-nav-link">{t('nav.home', lang)}</a>
          </li>
          <li>
            <a href="/work/" class="mobile-nav-link">{t('nav.work', lang)}</a>
          </li>
          <li>
            <a href="/experience/" class="mobile-nav-link">{t('nav.experience', lang)}</a>
          </li>
          <li>
            <a href="/#contact" class="mobile-nav-link">{t('nav.contact', lang)}</a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</header>

<script>
  function attachMobileMenuListeners() {
    const mobileMenuButton = document.getElementById('mobile-menu-button') as HTMLElement | null;
    const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;
    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.onclick = null;
      mobileMenuButton.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });
    }
    const mobileLinks = document.querySelectorAll('#mobile-menu a');
    mobileLinks.forEach(link => {
      (link as HTMLElement).onclick = null;
      link.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    attachMobileMenuListeners();
  });
  window.addEventListener('resize', () => {
    attachMobileMenuListeners();
  });

  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 64) {
      navbar?.classList.add('navbar-scrolled');
    } else {
      navbar?.classList.remove('navbar-scrolled');
    }
  });

</script>

<style>
  :global(.navbar-scrolled .surface-muted) {
    box-shadow: 0 28px 70px -34px rgba(31, 37, 45, 0.34);
  }

  .nav-link {
    position: relative;
    color: rgba(var(--color-secondary-rgb), 0.82);
    font-weight: 500;
    transition: color 0.3s ease;
  }

  :global(.dark) .nav-link {
    color: rgba(var(--color-secondary-rgb), 0.92);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -4px;
    left: 0;
    background-color: rgba(var(--color-primary-rgb), 1);
    transition: width 0.3s ease;
  }

  .nav-link:hover,
  .mobile-nav-link:hover {
    color: rgba(var(--color-primary-rgb), 1);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .mobile-nav-link {
    display: block;
    color: rgba(var(--color-secondary-rgb), 0.82);
    transition: color 0.3s ease;
  }

  :global(.dark) .mobile-nav-link {
    color: rgba(var(--color-secondary-rgb), 0.92);
  }
</style>
