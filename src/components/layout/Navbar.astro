---
import ThemeToggle from '../ui/ThemeToggle.astro';
import LanguageSwitcher from '../ui/LanguageSwitcher.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t, type SupportedLocale } from '../../utils/i18n';
import { normalizeLocale } from '../../utils/i18n';

interface Props {
  localeUrls?: Partial<Record<SupportedLocale, string>>;
}

const { localeUrls } = Astro.props;
const lang = normalizeLocale(Astro.currentLocale);
const pathname = Astro.url.pathname;
const homeHref = getRelativeLocaleUrl(lang);
const workHref = getRelativeLocaleUrl(lang, 'work');
const experienceHref = getRelativeLocaleUrl(lang, 'experience');
const blogHref = getRelativeLocaleUrl(lang, 'blog');
const contactHref = getRelativeLocaleUrl(lang, 'contact');

const isActive = (href: string) => {
  if (href === homeHref) {
    return pathname === href;
  }
  return pathname.startsWith(href);
};
---

<header id="navbar" class="fixed top-0 z-50 w-full transition-all duration-300">
  <div class="max-w-container mx-auto px-6 pt-4">
    <div class="surface-muted flex items-center justify-between px-4 py-3.5 shadow-button md:px-5 md:py-4">
      <a href={homeHref} class="brand-lockup" aria-label={t('nav.home', lang)}>
        <span class="brand-badge" aria-hidden="true">P</span>
        <span class="brand-wordmark text-[1.05rem] md:text-xl">Paulo Cesar Tuya</span>
      </a>

      <nav class="hidden md:flex items-center gap-5">
        <ul class="flex items-center gap-7 text-[0.95rem]">
          <li>
            <a href={homeHref} class:list={['nav-link', isActive(homeHref) && 'nav-link-active']}>{t('nav.home', lang)}</a>
          </li>
          <li>
            <a href={workHref} class:list={['nav-link', isActive(workHref) && 'nav-link-active']}>{t('nav.work', lang)}</a>
          </li>
          <li>
            <a href={experienceHref} class:list={['nav-link', isActive(experienceHref) && 'nav-link-active']}>{t('nav.experience', lang)}</a>
          </li>
          <li>
            <a href={blogHref} class:list={['nav-link', isActive(blogHref) && 'nav-link-active']}>{t('nav.blog', lang)}</a>
          </li>
          <li>
            <a href={contactHref} class:list={['contact-nav-button', isActive(contactHref) && 'contact-nav-button-active']}>{t('nav.contactButton', lang)}</a>
          </li>
        </ul>
        <LanguageSwitcher localeUrls={localeUrls} />
        <ThemeToggle />
      </nav>

      <div class="flex items-center gap-3 md:hidden">
        <ThemeToggle />
        <button
          id="mobile-menu-button"
          class="control-surface inline-flex h-11 w-11 items-center justify-center rounded-2xl"
          aria-label={t('ui.toggleMenuAria', lang)}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu">
            <line x1="4" x2="20" y1="12" y2="12"></line>
            <line x1="4" x2="20" y1="6" y2="6"></line>
            <line x1="4" x2="20" y1="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="mt-3 hidden md:hidden">
      <div class="surface-muted overflow-hidden px-5 py-5">
        <ul class="flex flex-col space-y-3 text-sm">
          <li>
            <a href={homeHref} class:list={['mobile-nav-link', isActive(homeHref) && 'mobile-nav-link-active']}>{t('nav.home', lang)}</a>
          </li>
          <li>
            <a href={workHref} class:list={['mobile-nav-link', isActive(workHref) && 'mobile-nav-link-active']}>{t('nav.work', lang)}</a>
          </li>
          <li>
            <a href={experienceHref} class:list={['mobile-nav-link', isActive(experienceHref) && 'mobile-nav-link-active']}>{t('nav.experience', lang)}</a>
          </li>
          <li>
            <a href={blogHref} class:list={['mobile-nav-link', isActive(blogHref) && 'mobile-nav-link-active']}>{t('nav.blog', lang)}</a>
          </li>
          <li>
            <a href={contactHref} class:list={['mobile-nav-link', 'mobile-nav-button', isActive(contactHref) && 'mobile-nav-link-active']}>{t('nav.contactButton', lang)}</a>
          </li>
        </ul>
        <div class="mt-5 border-t border-secondary/8 pt-4 dark:border-[rgba(var(--color-border-rgb),0.18)]">
          <LanguageSwitcher mobile={true} localeUrls={localeUrls} />
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  function attachMobileMenuListeners() {
    const mobileMenuButton = document.getElementById('mobile-menu-button') as HTMLElement | null;
    const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;
    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.onclick = () => {
        mobileMenu.classList.toggle('hidden');
      };
    }
    const mobileLinks = document.querySelectorAll('#mobile-menu a');
    mobileLinks.forEach(link => {
      (link as HTMLElement).onclick = () => {
        mobileMenu?.classList.add('hidden');
      };
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    attachMobileMenuListeners();
  });
  window.addEventListener('resize', () => {
    attachMobileMenuListeners();
  });

  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 64) {
      navbar?.classList.add('navbar-scrolled');
    } else {
      navbar?.classList.remove('navbar-scrolled');
    }
  });

</script>

<style>
  :global(.navbar-scrolled .surface-muted) {
    box-shadow: 0 28px 70px -34px rgba(31, 37, 45, 0.34);
  }

  .nav-link {
    position: relative;
    color: rgba(var(--color-secondary-rgb), 0.82);
    font-weight: 500;
    transition: color 0.3s ease;
  }

  :global(.dark) .nav-link {
    color: rgba(var(--color-secondary-rgb), 0.92);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -4px;
    left: 0;
    background-color: rgba(var(--color-primary-rgb), 1);
    transition: width 0.3s ease;
  }

  .nav-link:hover,
  .mobile-nav-link:hover {
    color: rgba(var(--color-primary-rgb), 1);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link-active {
    color: rgba(var(--color-primary-rgb), 1);
  }

  .nav-link-active::after {
    width: 100%;
  }

  .contact-nav-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(var(--color-primary-rgb), 1);
    background: rgba(var(--color-primary-rgb), 1);
    color: rgb(243, 238, 228);
    padding: 0.7rem 1.05rem;
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease, border-color 0.3s ease;
    box-shadow: 0 18px 40px -24px rgba(31, 37, 45, 0.35);
  }

  .contact-nav-button:hover {
    transform: translateY(-1px);
    background: rgba(var(--color-primary-rgb), 0.92);
    border-color: rgba(var(--color-primary-rgb), 0.92);
  }

  :global(.dark) .contact-nav-button {
    color: rgb(17, 22, 27);
    box-shadow: 0 18px 40px -24px rgba(0, 0, 0, 0.48);
  }

  .contact-nav-button-active {
    box-shadow: 0 20px 44px -24px rgba(var(--color-primary-rgb), 0.52);
  }

  .mobile-nav-link {
    display: block;
    border-radius: 1rem;
    color: rgba(var(--color-secondary-rgb), 0.82);
    padding: 0.75rem 0.9rem;
    transition: color 0.3s ease;
  }

  :global(.dark) .mobile-nav-link {
    color: rgba(var(--color-secondary-rgb), 0.92);
  }

  .mobile-nav-link:hover {
    background: rgba(var(--color-accent-surface-rgb), 0.42);
  }

  .mobile-nav-link-active {
    color: rgba(var(--color-primary-rgb), 1);
    background: rgba(var(--color-accent-surface-rgb), 0.5);
  }

  .mobile-nav-button {
    border: 1px solid rgba(var(--color-primary-rgb), 1);
    border-radius: 999px;
    background: rgba(var(--color-primary-rgb), 1);
    color: rgb(243, 238, 228);
    margin-top: 0.35rem;
    padding: 0.85rem 1rem;
    text-align: center;
    font-weight: 600;
  }

  :global(.dark) .mobile-nav-button {
    color: rgb(17, 22, 27);
  }
</style>
