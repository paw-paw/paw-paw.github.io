---
import Button from '../ui/Buttons.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { normalizeLocale, t } from '../../utils/i18n';

interface Props {
  lang: string | undefined;
  categoryMode?: boolean;
}

const locale = normalizeLocale(Astro.props.lang);
const { categoryMode = false } = Astro.props;
---

<div class="surface-muted px-6 py-10 md:px-10 md:py-12">
  <span class="section-eyebrow">{t('blog.eyebrow', locale)}</span>
  <h2 class="font-heading text-h2 text-secondary dark:text-fog mb-4">
    {categoryMode ? t('blog.emptyCategoryTitle', locale) : t('blog.emptyTitle', locale)}
  </h2>
  <p class="text-tone-soft max-w-2xl">
    {categoryMode ? t('blog.emptyCategoryText', locale) : t('blog.emptyText', locale)}
  </p>

  <div class="mt-8">
    <Button
      text={t('blog.emptyCta', locale)}
      href={getRelativeLocaleUrl(locale, 'work')}
      variant="primary"
      size="md"
    />
  </div>
</div>
