---
export interface Props {
  text: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  text,
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
} = Astro.props;

const variants = {
  primary: 'button-primary',
  secondary: 'button-secondary',
  outline: 'button-outline',
};

const sizes = {
  sm: 'px-4 py-2.5 text-sm',
  md: 'px-6 py-3 text-body',
  lg: 'px-8 py-4 text-lg',
};
---

<a
  href={href}
  class:list={[
    'inline-flex items-center justify-center rounded-full font-medium tracking-[-0.02em] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-button focus:outline-none focus:ring-2 focus:ring-primary/50 focus-visible:ring-2 focus-visible:ring-primary/50',
    variants[variant],
    sizes[size],
    className
  ]}
  data-aos="fade-up"
>
  {text}
  <slot />
</a>
