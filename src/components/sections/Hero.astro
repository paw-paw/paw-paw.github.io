---
import Button from '../ui/Buttons.astro';
import { t } from '../../utils/i18n';
import { Image } from 'astro:assets';
import heroPortrait from '../../assets/pawpaw-portrait.png';

const lang = Astro.currentLocale;
---

<section id="start" class="section-padding pt-32 md:pt-40">
  <div class="max-w-container mx-auto px-6">
    <div class="soft-grid surface-muted overflow-hidden px-6 py-8 md:px-10 md:py-10">
      <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-12">
        <div class="md:col-span-6">
          <span class="section-eyebrow">{t('hero.greeting', lang)}</span>
          <h1 class="mb-5 font-heading text-h1 text-secondary dark:text-fog">
            {t('hero.name', lang)}
          </h1>
          <p class="max-w-2xl text-lg text-secondary/78 dark:text-fog/78 md:text-xl">
            {t('hero.pitch', lang)}
          </p>
          <p class="mt-5 max-w-xl text-secondary/60 dark:text-fog/64">
            {t('hero.role', lang)}
          </p>

          <div class="mt-9 flex flex-wrap gap-4">
            <Button
              text={t('hero.ctaProjects', lang)}
              href="/work"
              variant="primary"
              size="md"
            />
            <Button
              text={t('hero.ctaAbout', lang)}
              href="/#how-i-work"
              variant="outline"
              size="md"
            />
          </div>
        </div>

        <div class="md:col-span-6">
          <div class="surface-card relative overflow-hidden p-4 md:p-5">
            <div class="absolute inset-0 bg-hero-glow opacity-70"></div>
            <div class="absolute inset-x-6 top-6 h-px bg-secondary/10 dark:bg-fog/10"></div>
            <div class="absolute bottom-6 left-6 flex items-center gap-3">
              <span class="brand-badge">P</span>
              <span class="font-mono text-[0.72rem] uppercase tracking-[0.2em] text-secondary/45 dark:text-fog/45">Pawpaw</span>
            </div>
            <div class="relative rounded-[1.75rem] bg-neutral-bg/70 dark:bg-neutral-darkSoft/75">
              <Image
                src={heroPortrait}
                alt="Illustrated portrait for the Pawpaw portfolio hero"
                class="mx-auto w-full max-w-md rounded-[1.75rem] object-cover"
                width="1024"
                height="1536"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="scroll-indicator" class="mt-10 flex justify-center">
    <button type="button" class="inline-flex items-center gap-3 rounded-full border border-secondary/10 bg-white/70 px-4 py-2 text-xs font-mono uppercase tracking-[0.18em] text-secondary/60 transition-colors duration-300 hover:border-primary/25 hover:text-primary dark:border-fog/10 dark:bg-neutral-darkSoft/70 dark:text-fog/62 dark:hover:text-highlightBlue" onclick="document.getElementById('how-i-work')?.scrollIntoView({ behavior: 'smooth' });">
      <span>Scroll</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14"></path>
        <path d="m19 12-7 7-7-7"></path>
      </svg>
    </button>
  </div>
</section>
