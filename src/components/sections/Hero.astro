---
import Button from '../ui/Buttons.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t } from '../../utils/i18n';
import { normalizeLocale } from '../../utils/i18n';
import { Image } from 'astro:assets';
import heroPortrait from '../../assets/paulo-hero.png';

const lang = normalizeLocale(Astro.currentLocale);
---

<section id="start" class="section-padding pt-28 md:pt-36">
  <div class="max-w-container mx-auto px-6">
    <div class="soft-grid surface-muted overflow-hidden px-6 py-8 md:px-10 md:py-10">
      <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-12">
        <div class="md:col-span-6">
          <span class="section-eyebrow">{t('hero.greeting', lang)}</span>
          <h1 class="mb-5 font-heading text-h1 text-secondary dark:text-fog">
            {t('hero.name', lang)}
          </h1>
          <p class="text-tone-soft max-w-2xl text-lg md:text-xl">
            {t('hero.pitch', lang)}
          </p>
          {t('hero.role', lang) && (
            <p class="text-tone-muted mt-5 max-w-xl">
              {t('hero.role', lang)}
            </p>
          )}

          <div class="mt-9 flex flex-wrap gap-4">
            <Button
              text={t('hero.ctaProjects', lang)}
              href={getRelativeLocaleUrl(lang, 'work')}
              variant="primary"
              size="md"
            />
            <Button
              text={t('hero.ctaAbout', lang)}
              href={getRelativeLocaleUrl(lang, 'experience')}
              variant="outline"
              size="md"
            />
          </div>
        </div>

        <div class="md:col-span-6">
          <div class="surface-card relative overflow-hidden p-4 md:p-5">
            <div class="absolute inset-0 bg-hero-glow opacity-70"></div>
            <div class="absolute inset-x-6 top-6 h-px bg-secondary/10 dark:bg-[rgba(var(--color-border-rgb),0.18)]"></div>
            <div class="relative rounded-[1.75rem] bg-neutral-bg/70 dark:bg-[rgba(var(--color-surface-nested-rgb),0.78)]">
              <Image
                src={heroPortrait}
                alt="Portrait of Paulo Cesar Tuya for the portfolio hero"
                class="mx-auto w-full max-w-md rounded-[1.75rem] object-cover"
                width="1024"
                height="1536"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="scroll-indicator" class="mt-10 flex justify-center">
    <button type="button" class="control-surface inline-flex items-center gap-3 rounded-full px-4 py-2 text-xs font-mono uppercase tracking-[0.18em] transition-colors duration-300 hover:border-primary/25 hover:text-primary dark:hover:text-highlightBlue" onclick="document.getElementById('selected-work')?.scrollIntoView({ behavior: 'smooth' });">
      <span>{t('hero.scrollLabel', lang)}</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14"></path>
        <path d="m19 12-7 7-7-7"></path>
      </svg>
    </button>
  </div>
</section>
