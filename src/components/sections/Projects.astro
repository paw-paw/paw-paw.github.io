---
import Button from '../ui/Buttons.astro';
import { t } from '../../utils/i18n';

interface Props {
  lang: string | undefined;
}

const { lang } = Astro.props;

const projects = [
  {
    title: 'Case study architecture in progress',
    slug: 'work',
    tags: ['Selected Work', 'Preview'],
    shortDescription: 'This preview will evolve into a curated set of delivery-oriented case studies after the final content layer is approved.'
  },
  {
    title: 'Project evidence will live on /work',
    slug: 'work',
    tags: ['Architecture', 'Content later'],
    shortDescription: 'Phase 2 defines the structure and destination of selected work without turning this preview into final content.'
  },
  {
    title: 'Deep-dive pages come next',
    slug: 'work',
    tags: ['Structure', 'Case studies'],
    shortDescription: 'This section now acts as a home preview that points to the future case-study surface.'
  }
];
---

<section id="selected-work" class="section-padding">
  <div class="max-w-container mx-auto px-6">
    <div class="mb-12" data-aos="fade-up">
      <span class="section-eyebrow">Evidence</span>
      <h2 class="font-heading text-h2 text-secondary dark:text-fog mb-4">{t('projects.title', lang)}</h2>
      <p class="text-secondary/70 dark:text-fog/72 max-w-2xl">
        {t('projects.subtitle', lang)}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      {projects.map((project, index) => (
        <div
          class="surface-card md:col-span-4 group overflow-hidden"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <div class="border-b border-secondary/8 p-6 dark:border-fog/10">
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-mono text-primary">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <div class="p-6">
            <h3 class="font-heading text-xl text-secondary dark:text-fog mb-3 group-hover:text-primary transition-colors duration-300">
              {project.title}
            </h3>
            <p class="mb-6 text-secondary/70 dark:text-fog/72">
              {project.shortDescription}
            </p>

            <Button
              text={t('projects.buttonText', lang)}
              href={`/${project.slug}`}
              variant="outline"
              size="sm"
            />
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center" data-aos="fade-up">
      <Button
        text={t('projects.allProjectsButtonText', lang)}
        href="/work"
        variant="primary"
      />
    </div>
  </div>
</section>
