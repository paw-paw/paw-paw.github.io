---
import Button from '../ui/Buttons.astro';
import { t } from '../../utils/i18n';
interface Props {
  lang: string | undefined;
}

const { lang } = Astro.props;
---

<section class="section-padding text-center">
  <div class="max-w-container mx-auto px-6">
    <div class="surface-muted px-8 py-10 md:px-12 md:py-14" data-aos="fade-up">
      <span class="section-eyebrow">Next step</span>
      <h2 class="font-heading text-h2 text-secondary dark:text-fog mb-6">
        {t('footerCTA.title', lang)}
      </h2>
      <p class="max-w-2xl mx-auto mb-8 text-secondary/70 dark:text-fog/72">
        {t('footerCTA.subtitle', lang)}
      </p>

      <Button
        text={t('footerCTA.buttonText', lang)}
        href="/#contact"
        variant="primary"
        size="lg"
      />
    </div>
  </div>
</section>
