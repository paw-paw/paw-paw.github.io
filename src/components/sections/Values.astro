---
import Button from '../ui/Buttons.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t } from '../../utils/i18n';
import { normalizeLocale } from '../../utils/i18n';

interface Props {
  lang: string | undefined;
}

const locale = normalizeLocale(Astro.props.lang);
---

<section id="how-i-work" class="section-padding bg-section-wash">
  <div class="max-w-container mx-auto px-6">
    <div class="mb-12 text-center" data-aos="fade-up">
      <span class="section-eyebrow">{t('values.eyebrow', locale)}</span>
      <h2 class="font-heading text-h2 text-secondary dark:text-fog mb-4">{t('values.title', locale)}</h2>
      <p class="text-secondary/74 dark:text-fog/88 max-w-2xl mx-auto">
        {t('values.subtitle', locale)}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div
        class="surface-card group p-8"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <div class="mb-6 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" role="img" aria-labelledby="performanceIconTitle">
            <title id="performanceIconTitle">{`${t('values.card1Title', locale)} ${t('ui.iconSuffix', locale)}`}</title>
            <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
        </div>
        <h3 class="font-heading text-xl text-secondary dark:text-fog mb-3 group-hover:text-primary transition-colors duration-300">{t('values.card1Title', locale)}</h3>
        <p class="text-secondary/76 dark:text-fog/88">
          {t('values.card1Text', locale)}
        </p>
      </div>

      <div
        class="surface-card group p-8"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        <div class="mb-6 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" role="img" aria-labelledby="accessibilityIconTitle">
            <title id="accessibilityIconTitle">{`${t('values.card2Title', locale)} ${t('ui.iconSuffix', locale)}`}</title>
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
        </div>
        <h3 class="font-heading text-xl text-secondary dark:text-fog mb-3 group-hover:text-primary transition-colors duration-300">{t('values.card2Title', locale)}</h3>
        <p class="text-secondary/76 dark:text-fog/88">
          {t('values.card2Text', locale)}
        </p>
      </div>

      <div
        class="surface-card group p-8"
        data-aos="fade-up"
        data-aos-delay="300"
      >
        <div class="mb-6 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" role="img" aria-labelledby="developerExperienceIconTitle">
            <title id="developerExperienceIconTitle">{`${t('values.card3Title', locale)} ${t('ui.iconSuffix', locale)}`}</title>
            <path d="M12 20v-6M9 20v-4M6 20v-2M15 20v-2M18 20v-4"></path>
            <path d="m4 4 2.5 2.5M19.1 8l-7.2 7.2M15 12V4h-8"></path>
          </svg>
        </div>
        <h3 class="font-heading text-xl text-secondary dark:text-fog mb-3 group-hover:text-primary transition-colors duration-300">{t('values.card3Title', locale)}</h3>
        <p class="text-secondary/76 dark:text-fog/88">
          {t('values.card3Text', locale)}
        </p>
      </div>
    </div>

    <div class="mt-10 text-center" data-aos="fade-up" data-aos-delay="360">
      <p class="text-tone-soft mx-auto mb-5 max-w-2xl">
        {t('values.blogLinkText', locale)}
      </p>
      <Button
        text={t('values.blogLinkCta', locale)}
        href={getRelativeLocaleUrl(locale, 'blog')}
        variant="outline"
        size="sm"
      />
    </div>
  </div>
</section>
