---
import Button from '../ui/Buttons.astro';
import { t } from '../../utils/i18n';
import { experienceItems } from '../../data/experience';

interface Props {
  lang: string | undefined;
}

const { lang } = Astro.props;
const previewItems = experienceItems.slice(0, 3);
---

<section id="experience-preview" class="section-padding bg-section-wash">
  <div class="max-w-container mx-auto px-6">
    <div class="mb-12" data-aos="fade-up">
      <span class="section-eyebrow">Trajectory</span>
      <h2 class="font-heading text-h2 text-secondary dark:text-fog mb-4">{t('timeline.title', lang)}</h2>
      <p class="text-secondary/70 dark:text-fog/82 max-w-2xl">
        {t('timeline.subtitle', lang)}
      </p>
    </div>

    <div id="timeline-container" class="surface-muted overflow-hidden px-6 py-8 md:px-8 md:py-10">
      <div class="space-y-6">
        {previewItems.map((item, index) => (
          <article
            class="surface-card p-6"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <div class="mb-3 flex flex-wrap items-center gap-3">
              <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-mono text-primary">
                {item.period}
              </span>
              <span class="text-xs font-mono uppercase tracking-[0.16em] text-secondary/45 dark:text-fog/68">
                {item.org}
              </span>
            </div>
            <h3 class="font-heading text-xl text-secondary dark:text-fog mb-3">
              {item.title}
            </h3>
            <p class="mb-4 text-secondary/70 dark:text-fog/82">
              {item.summary}
            </p>
            <div class="flex flex-wrap gap-2">
              {item.metrics.slice(0, 2).map((metric) => (
                <span class="rounded-full border border-secondary/10 px-3 py-1 text-xs font-mono text-secondary/70 dark:border-fog/10 dark:text-fog/76">
                  {metric}
                </span>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="mt-12 text-left md:text-center" data-aos="fade-up">
        <Button
          text={t('timeline.buttonText', lang)}
          href="/experience/"
          variant="outline"
        />
      </div>
    </div>
  </div>
</section>
