---
import Button from '../ui/Buttons.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t } from '../../utils/i18n';
import { normalizeLocale } from '../../utils/i18n';
import { getExperienceItems } from '../../data/experience';

interface Props {
  lang: string | undefined;
}

const locale = normalizeLocale(Astro.props.lang);
const previewItems = getExperienceItems(locale).slice(0, 3);
---

<section id="experience-preview" class="section-padding bg-section-wash">
  <div class="max-w-container mx-auto px-6">
    <div class="mb-12" data-aos="fade-up">
      <span class="section-eyebrow">{t('timeline.eyebrow', locale)}</span>
      <h2 class="font-heading text-h2 text-secondary dark:text-fog mb-4">{t('timeline.title', locale)}</h2>
      <p class="text-tone-soft max-w-2xl">
        {t('timeline.subtitle', locale)}
      </p>
    </div>

    <div id="timeline-container" class="surface-muted overflow-hidden px-6 py-8 md:px-8 md:py-10">
      <div class="space-y-6">
        {previewItems.map((item, index) => (
          <article
            class="surface-card experience-card experience-card-preview p-6"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <div class="experience-card-grid">
              <div class="experience-card-top">
                <div class="experience-logo-badge experience-logo-badge-preview">
                  {item.logo.allmode ? (
                    <img src={item.logo.allmode.src} alt={item.logo.alt} class="experience-logo-image experience-logo-image-preview" />
                  ) : (
                    <>
                      {item.logo.light && (
                        <img src={item.logo.light.src} alt={item.logo.alt} class="experience-logo-image experience-logo-image-preview dark:hidden" />
                      )}
                      {item.logo.dark && (
                        <img src={item.logo.dark.src} alt={item.logo.alt} class="experience-logo-image experience-logo-image-preview hidden dark:block" />
                      )}
                    </>
                  )}
                </div>

                <div class="experience-meta-stack experience-meta-stack-preview">
                  <span class="experience-period-pill">
                    {item.period}
                  </span>
                  <p class="experience-meta-line">
                    {item.location}
                  </p>
                  <p class="experience-meta-line">
                    {item.workMode}
                  </p>
                </div>

              </div>

              <div class="experience-card-body">
                <h3 class="font-heading text-xl text-secondary dark:text-fog mb-3">
                  {item.title}
                </h3>
                <p class="meta-kicker mb-3 text-sm font-mono uppercase tracking-[0.16em]">
                  {item.org}
                </p>
                <p class="text-tone-soft mb-4">
                  {item.summary}
                </p>
                <div class="flex flex-wrap gap-2">
                  {item.metrics.slice(0, 2).map((metric) => (
                    <span class="metric-chip">
                      {metric}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-12 text-left md:text-center" data-aos="fade-up">
        <Button
          text={t('timeline.buttonText', locale)}
          href={getRelativeLocaleUrl(locale, 'experience')}
          variant="outline"
        />
      </div>
    </div>
  </div>
</section>
