---
import Button from '../ui/Buttons.astro';
import { t } from '../../utils/i18n';

interface Props {
  lang: string | undefined;
}

const { lang } = Astro.props;

const timelineItems = ["item1", "item2", "item3"];
---

<section id="experience-preview" class="section-padding bg-section-wash">
  <div class="max-w-container mx-auto px-6">
    <div class="mb-12" data-aos="fade-up">
      <span class="section-eyebrow">Trajectory</span>
      <h2 class="font-heading text-h2 text-secondary dark:text-fog mb-4">{t('timeline.title', lang)}</h2>
      <p class="text-secondary/70 dark:text-fog/72 max-w-2xl">
        {t('timeline.subtitle', lang)}
      </p>
    </div>

    <div id="timeline-container" class="surface-muted relative overflow-hidden px-6 py-8 md:px-8 md:py-10">
      <div class="absolute bottom-0 left-0 top-0 w-px bg-secondary/10 dark:bg-fog/12 md:left-1/2 md:translate-x-px"></div>

      <div class="space-y-12">
        {timelineItems.map((item, index) => (
          <div
            class={`relative flex flex-col md:flex-row gap-8 md:gap-0 ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}
            data-aos={index % 2 === 0 ? "fade-left" : "fade-right"}
          >
            <div class="timeline-dot absolute left-0 top-0 h-5 w-5 -translate-x-2 rounded-full border-4 border-neutral-bg bg-primary md:left-1/2 md:-translate-x-2.5 dark:border-neutral-dark"></div>

            <div class="md:w-1/2 pl-10 md:pl-0 md:pr-12 md:text-right">
              <h3 class="font-heading text-xl text-secondary dark:text-fog mb-1">{t("timeline." + item + "Title", lang)}</h3>
              <p class="text-secondary/70 dark:text-fog/72">{t("timeline." + item + "Description", lang)}</p>
            </div>

            <div class="md:w-1/2 md:pl-12"></div>
          </div>
        ))}
      </div>

      <div class="mt-12 text-left md:text-center" data-aos="fade-up">
        <Button
          text={t('timeline.buttonText', lang)}
          href="/experience"
          variant="outline"
        />
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const timelineDots = document.querySelectorAll('.timeline-dot');

    gsap.from(timelineDots, {
      scrollTrigger: {
        trigger: '#timeline-container',
        start: 'top 80%',
      },
      scale: 0,
      opacity: 0,
      duration: 0.5,
      stagger: 0.2,
      ease: 'back.out(1.7)'
    });
  });
</script>
