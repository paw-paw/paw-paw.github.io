---
import { KanbanSquareIcon, MegaphoneIcon, LayoutDashboardIcon } from '@lucide/astro';

import { t } from '../../utils/i18n';
import { skillClusters } from '../../data/skills';

interface Props {
  lang: string | undefined;
}

const { lang } = Astro.props;
const clusterIcons = {
  'program-delivery-operations': KanbanSquareIcon,
  'partnerships-business-development': MegaphoneIcon,
  'systems-workflows-reporting': LayoutDashboardIcon,
};
const clustersWithIcons = skillClusters.map((cluster) => ({
  ...cluster,
  icon: clusterIcons[cluster.id as keyof typeof clusterIcons],
}));
---

<section id="skills" class="section-padding">
  <div class="max-w-container mx-auto px-6">
    <div class="mb-8 md:mb-10 text-center" data-aos="fade-up" data-aos-duration="800">
      <span class="section-eyebrow">Capability</span>
      <h2 class="font-heading text-h2 text-secondary dark:text-fog mb-4">{t('skills.title', lang)}</h2>
      <p class="text-secondary/70 dark:text-fog/82 max-w-2xl mx-auto">
        {t('skills.subtitle', lang)}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3 md:gap-8">
      {clustersWithIcons.map((cluster, index) => (
        <div
          id={cluster.id}
          class="surface-card skill-cluster p-6"
          data-aos="fade-up"
          data-aos-duration="600"
          data-aos-delay={index * 150}
        >
          <div class="cluster-header flex items-center mb-4">
            <div class="icon-container mr-4 rounded-2xl bg-primary/10 p-3 text-primary">
              <cluster.icon size={26} stroke-width={1.75} />
            </div>
            <h3 class="font-heading text-xl text-secondary dark:text-fog">
              {cluster.title}
            </h3>
          </div>

          <p class="mb-4 cluster-description text-secondary/70 dark:text-fog/82">
            {cluster.description}
          </p>

          <ul class="mb-6 space-y-3 text-sm text-secondary/78 dark:text-fog/82">
            {cluster.capabilities.map((capability) => (
              <li class="flex gap-3">
                <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-primary/70"></span>
                <span>{capability}</span>
              </li>
            ))}
          </ul>

          <div class="flex flex-wrap gap-2">
            {cluster.tools.map((tool) => (
              <span class="rounded-full border border-secondary/10 px-3 py-1 text-xs font-mono text-secondary/70 dark:border-fog/10 dark:text-fog/76">
                {tool}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
