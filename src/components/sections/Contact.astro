---
import Obfuscate from 'react-obfuscate';

import { t } from '../../utils/i18n';
import { email, linkedin_short, linkedin_url, instagram_short, instagram_url } from '../../utils/me';

interface Props {
  lang: string | undefined;
  compactHeader?: boolean;
}

const { lang, compactHeader = false } = Astro.props;
---

<section id="contact" class="section-padding">
  <div class="max-w-container mx-auto px-6">
    <div class="surface-muted px-6 py-8 md:px-8 md:py-10">
      {!compactHeader && (
        <div class="mb-12 text-center" data-aos="fade-up">
          <span class="section-eyebrow">Contact</span>
          <h2 class="font-heading text-h2 text-secondary dark:text-fog mb-4">
            {t('contact.title', lang)}
          </h2>
          <p class="max-w-2xl mx-auto text-secondary/74 dark:text-fog/86">
            {t('contact.subtitle', lang)}
          </p>
        </div>
      )}

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <Obfuscate
        email={email}
        obfuscateChildren={false}
        client:only="preact"
        className="surface-card group p-8 text-center"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <div class="relative mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-primary/14 text-primary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary"
            role="img"
            aria-labelledby="emailContactIconTitle"
          >
            <title id="emailContactIconTitle">
              {t('contact.emailTitle', lang)} Icon
            </title>
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>

          <div id="email-animation" class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </div>

        <h3 class="mb-3 font-heading text-xl text-secondary dark:text-fog">
          {t('contact.emailTitle', lang)}
        </h3>
        <p class="mb-4 text-secondary/76 dark:text-fog/88">
          <Obfuscate element="span" email={email} client:only="preact" />
        </p>
        <span class="inline-flex items-center text-sm text-primary font-medium">
          <span>{t('contact.emailButtonText', lang)}</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="ml-1"
            role="img"
            aria-labelledby="emailArrowIconTitle"
          >
            <title id="emailArrowIconTitle">
              {t('contact.emailButtonText', lang)} Arrow
            </title>
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </span>
      </Obfuscate>

      <a
        href={linkedin_url}
        target="_blank"
        rel="noopener noreferrer"
        class="surface-card group p-8 text-center"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-primary/14 text-primary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary"
            role="img"
            aria-labelledby="linkedinContactIconTitle"
          >
            <title id="linkedinContactIconTitle">
              {t('contact.linkedinTitle', lang)} Icon
            </title>
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
            <rect width="4" height="12" x="2" y="9"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </div>

        <h3 class="mb-3 font-heading text-xl text-secondary dark:text-fog">
          {t('contact.linkedinTitle', lang)}
        </h3>
        <p class="mb-4 text-secondary/76 dark:text-fog/88">
          {linkedin_short}
        </p>
        <span class="inline-flex items-center text-sm text-primary font-medium">
          {t('contact.linkedinButtonText', lang)}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="ml-1"
            role="img"
            aria-labelledby="linkedinArrowIconTitle"
          >
            <title id="linkedinArrowIconTitle">
              {t('contact.linkedinButtonText', lang)} Arrow
            </title>
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </span>
      </a>

      <a
        href={instagram_url}
        target="_blank"
        rel="noopener noreferrer"
        class="surface-card group p-8 text-center"
        data-aos="fade-up"
        data-aos-delay="300"
      >
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-primary/14 text-primary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary"
            role="img"
            aria-labelledby="instagramContactIconTitle"
          >
            <title id="instagramContactIconTitle">
              {t('contact.instagramTitle', lang)} Icon
            </title>
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37a4 4 0 1 1-7.75 1.37 4 4 0 0 1 7.75-1.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </div>

        <h3 class="mb-3 font-heading text-xl text-secondary dark:text-fog">
          {t('contact.instagramTitle', lang)}
        </h3>
        <p class="mb-4 text-secondary/76 dark:text-fog/88">
          {instagram_short}
        </p>
        <span class="inline-flex items-center text-sm text-primary font-medium">
          {t('contact.instagramButtonText', lang)}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="ml-1"
            role="img"
            aria-labelledby="instagramArrowIconTitle"
          >
            <title id="instagramArrowIconTitle">
              {t('contact.instagramButtonText', lang)} Arrow
            </title>
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </span>
      </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const emailCard = document.querySelector('a[href^="mailto"]');
    const emailAnimation = document.getElementById('email-animation');

    if (emailCard && emailAnimation) {
      emailCard.addEventListener('mouseenter', () => {
        gsap.to('#email-animation', {
          opacity: 1,
          duration: 0.3,
        });

        // This is where you'd normally initialize a Lottie animation
        // For this demo, we'll create a simple paper plane with GSAP
        const paperPlane = document.createElement('div');
        paperPlane.style.position = 'absolute';
        paperPlane.style.width = '20px';
        paperPlane.style.height = '20px';
        paperPlane.style.backgroundColor = 'transparent';
        paperPlane.style.left = '50%';
        paperPlane.style.top = '50%';
        paperPlane.style.transform = 'translate(-50%, -50%)';

        emailAnimation.innerHTML = '';
        emailAnimation.appendChild(paperPlane);

        // Simple animation
        gsap.fromTo(
          paperPlane,
          { opacity: 0, scale: 0.5 },
          {
            opacity: 1,
            scale: 1,
            rotation: 360,
            duration: 0.8,
            ease: 'back.out(1.7)',
          },
        );
      });

      emailCard.addEventListener('mouseleave', () => {
        gsap.to('#email-animation', {
          opacity: 0,
          duration: 0.3,
        });
      });
    }
  });
</script>
