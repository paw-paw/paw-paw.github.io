---
import type { ImageMetadata } from 'astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import '../styles/global.css';
import { normalizeLocale, t, type SupportedLocale } from '../utils/i18n';
import faviconAsset from '../assets/brand/monogram-light.png';
import profileImg from '../assets/paulo-hero.png';
import { name, linkedin_url, instagram_url } from '../utils/me';
import { defaultIndexedUrl } from '../utils/seo';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  localeUrls?: Partial<Record<SupportedLocale, string>>;
  seoImage?: string;
  ogType?: 'website' | 'article';
  socialImage?: ImageMetadata;
  schemaMode?: 'default' | 'home' | 'experience';
}

const lang = normalizeLocale(Astro.props.lang || 'en');

const {
  title = t('site.title', lang),
  description = t('site.description', lang),
  localeUrls,
  seoImage,
  ogType = 'website',
  socialImage = profileImg,
  schemaMode = 'default',
} = Astro.props;

const sameAs = [linkedin_url, instagram_url].filter(Boolean);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site!).href;
const pathWithoutLocale = Astro.url.pathname.replace(/^\/(en|es)(?=\/|$)/, '') || '/';
const normalizedPath = pathWithoutLocale.startsWith('/') ? pathWithoutLocale : `/${pathWithoutLocale}`;
const defaultLocaleUrls: Record<SupportedLocale, string> = {
  en: `/en${normalizedPath === '/' ? '/' : normalizedPath}`,
  es: `/es${normalizedPath === '/' ? '/' : normalizedPath}`,
};
const resolvedLocaleUrls = { ...defaultLocaleUrls, ...localeUrls };
const alternateEn = resolvedLocaleUrls.en ? new URL(resolvedLocaleUrls.en, Astro.site!).href : undefined;
const alternateEs = resolvedLocaleUrls.es ? new URL(resolvedLocaleUrls.es, Astro.site!).href : undefined;
const websiteUrl = defaultIndexedUrl;
const socialImageUrl = seoImage
  ? new URL(seoImage, Astro.site!).href
  : new URL(socialImage.src, Astro.site!).href;
const logoUrl = new URL(faviconAsset.src, Astro.site!).href;
const localizedJobTitle = t('hero.role', lang).trim();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name,
  url: websiteUrl,
  image: socialImageUrl,
  description,
  sameAs,
  ...(localizedJobTitle ? { jobTitle: localizedJobTitle } : {}),
};

const organizationSchema = schemaMode === 'home'
  ? {
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name,
      url: canonicalUrl,
      description,
      image: socialImageUrl,
      logo: logoUrl,
      sameAs,
    }
  : null;

const profilePageSchema = schemaMode === 'experience'
  ? {
      '@context': 'https://schema.org',
      '@type': 'ProfilePage',
      url: canonicalUrl,
      name: title,
      description,
      mainEntity: {
        '@type': 'Person',
        name,
        url: websiteUrl,
        image: socialImageUrl,
        description,
        sameAs,
      },
    }
  : null;
---

<!DOCTYPE html>
<html lang={lang || 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="icon" type="image/png" href={faviconAsset.src} />
    <link rel="canonical" href={canonicalUrl} />
    {alternateEn && <link rel="alternate" hreflang="en" href={alternateEn} />}
    {alternateEs && <link rel="alternate" hreflang="es" href={alternateEs} />}
    {alternateEn && <link rel="alternate" hreflang="x-default" href={alternateEn} />}

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:site_name" content="Paulo Tuya" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": websiteUrl,
      "name": "Paulo Tuya"
    })} />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    {organizationSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    )}
    {profilePageSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(profilePageSchema)} />
    )}
  </head>
  <body class="transition-colors duration-300">
    <div class="flex flex-col min-h-screen">
      <Navbar localeUrls={resolvedLocaleUrls} />
      <main class="flex-grow">
        <slot />
      </main>
      <Footer lang={lang} />
    </div>

    <script is:inline src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        AOS.init({
          duration: 800,
          easing: 'ease-out',
          once: false,
          offset: 50,
        });
      });
    </script>

    <script src="../scripts/animations.js"></script>
  </body>
</html>
