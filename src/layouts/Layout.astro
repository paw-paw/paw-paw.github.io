---
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import '../styles/global.css';
import { t } from '../utils/i18n';
import faviconAsset from '../assets/favicon.svg';
import profileImg from '../assets/pawpaw-portrait.png';
import { name, linkedin_url, instagram_url } from '../utils/me';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const lang = Astro.props.lang || 'en';

const {
  title = t('site.title', lang),
  description = t('site.description', lang)
} = Astro.props;

const sameAs = [linkedin_url, instagram_url].filter(Boolean);
---

<!DOCTYPE html>
<html lang={lang || 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href={faviconAsset.src} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site!).href} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site!).href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(profileImg.src, Astro.site!).href} />
    <meta property="og:site_name" content={t('site.title', lang)} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={new URL(Astro.url.pathname, Astro.site!).href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(profileImg.src, Astro.site!).href} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": Astro.site!.href,
      "name": t('site.title', lang)
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": name,
      "url": Astro.site!.href,
      "image": new URL(profileImg.src, Astro.site!).href,
      "jobTitle": t('hero.role', lang),
      "description": description,
      "sameAs": sameAs
    })} />
  </head>
  <body class="text-secondary transition-colors duration-300 dark:text-fog">
    <div class="flex flex-col min-h-screen">
      <Navbar />
      <main class="flex-grow">
        <slot />
      </main>
      <Footer lang={lang} />
    </div>

    <script is:inline src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        AOS.init({
          duration: 800,
          easing: 'ease-out',
          once: false,
          offset: 50,
        });
      });
    </script>

    <script src="../scripts/animations.js"></script>
  </body>
</html>
