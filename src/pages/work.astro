---
import Layout from '../layouts/Layout.astro';
import { t } from '../utils/i18n';

const lang = 'en';
---

<Layout
  title={`Work | ${t('site.title', lang)}`}
  description="Selected work and case studies will be structured here. Final case content is still being assembled."
  lang={lang}
>
  <section class="pt-28 pb-16 md:pt-36 md:pb-24">
    <div class="max-w-container mx-auto px-6">
      <div class="max-w-3xl">
        <span class="font-mono text-primary text-sm mb-4 block">Selected Work</span>
        <h1 class="font-heading text-h1 text-secondary dark:text-white mb-4">
          Work and case studies are being structured.
        </h1>
        <p class="text-lg md:text-xl text-secondary/80 dark:text-white/80 mb-6">
          This page will house the deeper view of selected work once the content model and final case curation are complete.
        </p>
        <p class="text-secondary/70 dark:text-white/70 max-w-2xl">
          Phase 2 establishes the architecture and the minimum case-study structure. Final case content will be completed in later phases.
        </p>
      </div>
    </div>
  </section>
</Layout>
