---
import profileImg from '../assets/paulo-hero.png';
import { getSeoEntry } from '../utils/seo';

const seo = getSeoEntry('en', 'home');
const canonicalUrl = new URL('/', Astro.site!).href;
const previewImage = new URL(profileImg.src, Astro.site!).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="robots" content="noindex" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={previewImage} />
    <meta property="og:site_name" content="Paulo Tuya" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={seo.title} />
    <meta property="twitter:description" content={seo.description} />
    <meta property="twitter:image" content={previewImage} />
  </head>
  <body>
    <noscript>
      <p><a href="/en/">Continue in English</a></p>
      <p><a href="/es/">Continuar en español</a></p>
    </noscript>

    <script is:inline>
      const supportedLocales = ['en', 'es'];
      const preferredLocale = window.localStorage.getItem('preferred-locale');
      const browserLocales = (navigator.languages || [navigator.language])
        .map((locale) => locale.toLowerCase())
        .map((locale) => locale.split('-')[0]);

      const browserLocale = browserLocales.find((locale) => supportedLocales.includes(locale));
      const locale = supportedLocales.includes(preferredLocale) ? preferredLocale : browserLocale || 'en';
      window.location.replace(`/${locale}${'/'}`);
    </script>
  </body>
</html>
