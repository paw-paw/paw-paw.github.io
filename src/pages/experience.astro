---
import Layout from '../layouts/Layout.astro';
import { t } from '../utils/i18n';

const lang = 'en';
---

<Layout
  title={`Experience | ${t('site.title', lang)}`}
  description="Experience highlights and role history will be structured here. Final role selection and copy are still being refined."
  lang={lang}
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="max-w-container mx-auto px-6">
      <div class="surface-muted max-w-4xl px-8 py-10 md:px-10 md:py-12">
        <span class="section-eyebrow">Experience</span>
        <h1 class="font-heading text-h1 text-secondary dark:text-fog mb-4">
          Experience architecture is now in place.
        </h1>
        <p class="text-lg md:text-xl text-secondary/78 dark:text-fog/78 mb-6">
          This page will become the deeper surface for role history, ownership, and delivery evidence once the final content layer is ready.
        </p>
        <p class="max-w-2xl text-secondary/68 dark:text-fog/68">
          Phase 2 defines how experience will be represented. Final role selection, highlights, and approved copy will be completed in later phases.
        </p>
      </div>
    </div>
  </section>
</Layout>
