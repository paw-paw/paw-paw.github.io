---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../utils/i18n';
import { getSelectedWork } from '../../data/selected-work';
import { getSeoEntry } from '../../utils/seo';

const lang = 'en';
const selectedWork = getSelectedWork(lang);
const seo = getSeoEntry(lang, 'work');
---

<Layout
  title={seo.title}
  description={seo.description}
  lang={lang}
>
  <section class="section-padding pt-28 md:pt-36">
    <div class="max-w-container mx-auto px-6">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,2fr)_minmax(20rem,0.95fr)]">
        <div class="surface-muted px-8 py-10 md:px-10 md:py-12">
          <span class="section-eyebrow">{t('workPage.eyebrow', lang)}</span>
          <h1 class="font-heading text-h1 text-secondary dark:text-fog mb-4">
            {t('workPage.title', lang)}
          </h1>
          <p class="text-tone-soft text-lg md:text-xl">
            {t('workPage.subtitle', lang)}
          </p>
        </div>

        <aside class="surface-card work-panel p-6 md:p-7">
          <span class="section-eyebrow mb-5">{t('workPage.panelTitle', lang)}</span>
          <div class="space-y-4">
            <div class="nested-panel-card">
              <p class="nested-panel-label">{t('workPage.panelDealsClosedLabel', lang)}</p>
              <p class="nested-panel-value">{t('workPage.panelDealsClosedValue', lang)}</p>
            </div>
            <div class="nested-panel-card">
              <p class="nested-panel-label">{t('workPage.panelProgramsDeliveredLabel', lang)}</p>
              <p class="nested-panel-value">{t('workPage.panelProgramsDeliveredValue', lang)}</p>
            </div>
            <div class="nested-panel-card">
              <p class="nested-panel-label">{t('workPage.panelBudgetsManagedLabel', lang)}</p>
              <p class="nested-panel-value">{t('workPage.panelBudgetsManagedValue', lang)}</p>
            </div>
            <div class="nested-panel-card">
              <p class="nested-panel-label">{t('workPage.panelDeliveryContextsLabel', lang)}</p>
              <p class="nested-panel-value">{t('workPage.panelDeliveryContextsValue', lang)}</p>
            </div>
          </div>
        </aside>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-8 lg:grid-cols-2">
        {selectedWork.map((item, index) => (
          <article
            class="surface-card overflow-hidden"
            data-aos="fade-up"
            data-aos-delay={index * 80}
          >
            <div class="work-card-header">
              <img
                src={item.headerImage.src}
                alt={item.headerAlt}
                class="work-card-header-image"
                loading="lazy"
              />
              <div class="work-card-header-overlay" aria-hidden="true"></div>
            </div>

            <div class="border-b border-secondary/8 p-6 dark:border-[rgba(var(--color-border-rgb),0.18)]">
              <div class="flex flex-wrap gap-2">
                {item.tags.map((tag) => (
                  <span class="tag-chip">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <div class="p-6">
              <p class="meta-kicker mb-2 text-xs font-mono uppercase tracking-[0.16em]">
                {item.role} · {item.org}
              </p>
              <h2 class="mb-3 font-heading text-2xl text-secondary dark:text-fog">
                {item.title}
              </h2>
              <p class="text-tone-muted mb-1 text-sm">
                {item.period} · {item.location}
              </p>
              <p class="text-tone-soft mb-5">
                {item.summary}
              </p>

              <ul class="text-tone-soft mb-6 space-y-3 text-sm">
                {item.highlights.map((highlight) => (
                  <li class="flex gap-3">
                    <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-primary/70"></span>
                    <span>{highlight}</span>
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-2">
                {item.metrics.map((metric) => (
                  <span class="metric-chip">
                    {metric}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
