---
import Layout from '../../../layouts/Layout.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';
import { getFeaturedBlogPostsByLocale, getBlogPostsByLocale } from '../../../utils/blog';
import { getSeoEntry } from '../../../utils/seo';
import { t } from '../../../utils/i18n';

const lang = 'en';
const seo = getSeoEntry(lang, 'blog');
const featuredPosts = await getFeaturedBlogPostsByLocale(lang);
const allPosts = await getBlogPostsByLocale(lang);
---

<Layout title={seo.title} description={seo.description} lang={lang}>
  <section class="section-padding pt-28 md:pt-36">
    <div class="max-w-container mx-auto px-6">
      <div class="surface-muted px-6 py-8 md:px-10 md:py-12" data-aos="fade-up">
        <span class="section-eyebrow">{t('blog.eyebrow', lang)}</span>
        <h1 class="font-heading text-h1 text-secondary dark:text-fog mb-4">{t('blog.title', lang)}</h1>
        <p class="text-tone-soft max-w-3xl text-lg md:text-xl">{t('blog.subtitle', lang)}</p>
      </div>

      {featuredPosts.length > 0 && (
        <div class="mt-10 md:mt-12">
          <div class="mb-6">
            <span class="section-eyebrow">{t('blog.featuredTitle', lang)}</span>
          </div>
          <div class="grid gap-6 lg:grid-cols-2">
            {featuredPosts.map((post) => (
              <BlogCard post={post} lang={lang} />
            ))}
          </div>
        </div>
      )}

      <div class="mt-10 md:mt-12">
        <div class="mb-6">
          <span class="section-eyebrow">{t('blog.allPostsTitle', lang)}</span>
        </div>
        <div class="grid gap-6 lg:grid-cols-2">
          {allPosts.map((post) => (
            <BlogCard post={post} lang={lang} />
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
