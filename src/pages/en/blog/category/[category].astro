---
import Layout from '../../../../layouts/Layout.astro';
import BlogCard from '../../../../components/blog/BlogCard.astro';
import BlogEmptyState from '../../../../components/blog/BlogEmptyState.astro';
import { blogCategories, blogCategoryLabelKey, getBlogPostsByLocaleAndCategory } from '../../../../utils/blog';
import { getSeoEntry } from '../../../../utils/seo';
import { t } from '../../../../utils/i18n';

export async function getStaticPaths() {
  return blogCategories.map((category) => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.props;
const lang = 'en';
const seo = getSeoEntry(lang, 'blog');
const posts = await getBlogPostsByLocaleAndCategory(lang, category);
const categoryLabel = t(blogCategoryLabelKey[category], lang);
---

<Layout title={`${categoryLabel} | ${seo.title}`} description={seo.description} lang={lang}>
  <section class="section-padding pt-28 md:pt-36">
    <div class="max-w-container mx-auto px-6">
      <div class="surface-muted px-6 py-8 md:px-10 md:py-12 mb-10 md:mb-12" data-aos="fade-up">
        <span class="section-eyebrow">{t('blog.categoryLabel', lang)}</span>
        <h1 class="font-heading text-h1 text-secondary dark:text-fog mb-4">{categoryLabel}</h1>
        <p class="text-tone-soft max-w-3xl text-lg md:text-xl">{t('blog.subtitle', lang)}</p>
      </div>

      {posts.length > 0 ? (
        <div class="grid gap-6 lg:grid-cols-2">
          {posts.map((post) => (
            <BlogCard post={post} lang={lang} />
          ))}
        </div>
      ) : (
        <BlogEmptyState lang={lang} categoryMode={true} />
      )}
    </div>
  </section>
</Layout>
