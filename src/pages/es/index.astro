---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/sections/Hero.astro';
import Values from '../../components/sections/Values.astro';
import Projects from '../../components/sections/Projects.astro';
import Timeline from '../../components/sections/Timeline.astro';
import Skills from '../../components/sections/Skills.astro';
import FooterCTA from '../../components/sections/FooterCTA.astro';
import { getSeoEntry } from '../../utils/seo';

const lang = 'es';
const seo = getSeoEntry(lang, 'home');
---

<Layout title={seo.title} description={seo.description} lang={lang}>
  <Hero lang={lang} />
  <Projects lang={lang} />
  <Timeline lang={lang} />
  <Values lang={lang} />
  <Skills lang={lang} />
  <FooterCTA lang={lang} />
</Layout>
