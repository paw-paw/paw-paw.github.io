---
import Layout from '../../../layouts/Layout.astro';
import BlogEmptyState from '../../../components/blog/BlogEmptyState.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getSeoEntry } from '../../../utils/seo';
import { t } from '../../../utils/i18n';

const lang = 'es';
const seo = getSeoEntry(lang, 'blog');
const englishBlogHref = getRelativeLocaleUrl('en', 'blog');
---

<Layout title={seo.title} description={seo.description} lang={lang}>
  <section class="section-padding pt-28 md:pt-36">
    <div class="max-w-container mx-auto px-6">
      <div class="grid gap-6 md:gap-8 lg:grid-cols-[minmax(0,2fr)_minmax(20rem,0.95fr)]">
        <div class="surface-muted px-6 py-8 md:px-10 md:py-12" data-aos="fade-up">
          <span class="section-eyebrow">{t('blog.eyebrow', lang)}</span>
          <h1 class="font-heading text-h1 text-secondary dark:text-fog mb-4">{t('blog.title', lang)}</h1>
          <p class="text-tone-soft max-w-3xl text-lg md:text-xl">{t('blog.subtitle', lang)}</p>
        </div>

        <aside class="surface-card p-5 md:p-6" data-aos="fade-up" data-aos-delay="120">
          <span class="section-eyebrow">{t('blog.featuredTitle', lang)}</span>
          <h2 class="font-heading text-2xl text-secondary dark:text-fog mb-4">
            {t('blog.featuredPanelEmptyTitle', lang)}
          </h2>
          <p class="text-tone-soft">
            {t('blog.featuredPanelEmptyText', lang)}
          </p>
        </aside>
      </div>

      <div class="mt-10 md:mt-12">
        <BlogEmptyState lang={lang} ctaHref={englishBlogHref} ctaText={t('blog.emptyLaunchCta', lang)} />
      </div>
    </div>
  </section>
</Layout>
